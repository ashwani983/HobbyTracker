rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Partners and shared stats: any authenticated user can read
    match /users/{userId}/partners/{partnerId} {
      allow read, write: if request.auth != null;
    }
    match /users/{userId}/shared_stats/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Challenges: any authenticated user can read, create, update, delete
    match /challenges/{challengeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;

      // Participants subcollection
      match /participants/{participantId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
    }

    // Partner requests: any authenticated user can read/write
    match /partner_requests/{code} {
      allow read, write: if request.auth != null;
    }
  }
}
